name: Build APK Natively

on:
push:
branches:
- main
- master
workflow_dispatch:

jobs:
build:
runs-on: ubuntu-22.04

```
steps:
  - name: Checkout Repository
    uses: actions/checkout@v4

  - name: Setup Python
    uses: actions/setup-python@v5
    with:
      python-version: "3.11"

  - name: Install System Dependencies
    run: |
      sudo apt-get update

      sudo apt-get install -y \
        build-essential \
        git \
        zip \
        unzip \
        openjdk-17-jdk \
        autoconf \
        automake \
        libtool \
        pkg-config \
        zlib1g-dev \
        libncurses5-dev \
        libncursesw5-dev \
        libtinfo5 \
        cmake \
        libffi-dev \
        libssl-dev \
        python3-dev \
        wget \
        curl

  - name: Install Buildozer
    run: |
      python -m pip install --upgrade pip setuptools wheel
      pip install "cython<3.0"
      pip install buildozer

  - name: Create buildozer.spec if Missing
    run: |
      if [ ! -f buildozer.spec ]; then
        buildozer init
      fi

  - name: Configure Buildozer
    run: |

      sed -i 's/^log_level = .*/log_level = 2/' buildozer.spec

      sed -i 's/^requirements = .*/requirements = python3,kivy==2.3.0/' buildozer.spec

      sed -i 's/^# android.api = .*/android.api = 33/' buildozer.spec
      sed -i 's/^# android.minapi = .*/android.minapi = 24/' buildozer.spec
      sed -i 's/^# android.ndk = .*/android.ndk = 25b/' buildozer.spec

      sed -i 's/^# android.accept_sdk_license = False/android.accept_sdk_license = True/' buildozer.spec

      grep -q "^android.api =" buildozer.spec || echo "android.api = 33" >> buildozer.spec
      grep -q "^android.minapi =" buildozer.spec || echo "android.minapi = 24" >> buildozer.spec
      grep -q "^android.ndk =" buildozer.spec || echo "android.ndk = 25b" >> buildozer.spec
      grep -q "^android.accept_sdk_license =" buildozer.spec || echo "android.accept_sdk_license = True" >> buildozer.spec

  - name: Clean Previous Builds
    run: |
      rm -rf .buildozer
      buildozer android clean || true

  - name: Build APK
    run: |
      buildozer -v android debug

  - name: Upload APK
    uses: actions/upload-artifact@v4
    with:
      name: Android-APK
      path: bin/*.apk
```
